# ==============================
# App environment
# ==============================
NODE_ENV=development

# ==============================
# Local MySQL 8.0 (Docker)
# Used by database/docker-compose.mysql.yml and local CLI commands.
# ==============================
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=tarifario_inbioslab
LOCAL_DB_USER=inbioslab
LOCAL_DB_PASSWORD=change_me_local_password
LOCAL_DB_ROOT_USER=root
LOCAL_DB_ROOT_PASSWORD=change_me_local_root_password

# phpMyAdmin local
PMA_HOST=mysql
PMA_PORT=3306
PMA_HTTP_PORT=8080

# ==============================
# Google Cloud SQL (Production)
# Do NOT commit real production values.
# If using Cloud SQL Connector or private IP, DB_HOST may be private IP/hostname.
# ==============================
PROD_DB_HOST=127.0.0.1
PROD_DB_PORT=3306
PROD_DB_NAME=tarifario_inbioslab
PROD_DB_USER=cloudsql_user
PROD_DB_PASSWORD=change_me_prod_password

# Optional Cloud SQL metadata
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
CLOUD_SQL_INSTANCE=your-project:region:instance-name
