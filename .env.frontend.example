# Frontend (Vite) environment template
# Copy to .env.local for local dev, and configure production values in your CI/CD.
# Vite exposes ONLY variables prefixed with VITE_ to client code.

# ------------------------------
# Local development
# ------------------------------
VITE_APP_ENV=development
VITE_USE_API=true
VITE_API_BASE_URL=http://localhost:8081/api
VITE_ASSETS_BASE_URL=/
VITE_WHATSAPP_PHONE=51999999999
VITE_ENABLE_ADMIN_SHORTCUT=false
VITE_ADMIN_API_KEY=change_me_local_admin_key

# ------------------------------
# Production (Cloud Run backend)
# ------------------------------
# Use your Cloud Run service URL (or custom domain)
VITE_USE_API_PROD=true
VITE_API_BASE_URL_PROD=https://tarifario-api-1006817694622.us-central1.run.app/api
VITE_APP_ENV_PROD=production
VITE_ADMIN_API_KEY_PROD=change_me_prod_admin_key
