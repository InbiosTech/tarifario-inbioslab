{
  "name": "tarifario-inbioslab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "web:port:free": "kill-port 5173 5174 5175 5176 5177",
    "dev": "npm run web:port:free && vite --port 5173 --strictPort",
    "dev:full": "concurrently -k -n API,WEB -c green,blue \"npm run api:dev:clean\" \"npm run dev\"",
    "build": "vite build --mode production",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "db:seed:generate": "node scripts/db/generate-seed-sql.mjs",
    "db:local:up": "docker compose -f database/docker-compose.mysql.yml up -d",
    "db:local:down": "docker compose -f database/docker-compose.mysql.yml down",
    "db:local:logs": "docker compose -f database/docker-compose.mysql.yml logs -f",
    "db:local:init": "node backend/scripts/init-local-db.mjs",
    "api:install": "npm --prefix backend install",
    "api:port:free": "kill-port 8081",
    "api:dev:clean": "npm run api:port:free && npm run api:dev",
    "api:dev": "npm --prefix backend run dev",
    "api:start": "npm --prefix backend run start"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.1",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "eslint": "^9.8.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "gh-pages": "^6.3.0",
    "globals": "^15.9.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.0"
  }
}
