# Backend/API environment template
# Copy to backend/.env for local execution.
# In Cloud Run, set these as service environment variables (do not store secrets in repo).

# ------------------------------
# Runtime
# ------------------------------
NODE_ENV=development
API_PORT=8081
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
WRITE_API_KEY=change_me_local_admin_key
ADMIN_API_KEY=change_me_local_super_admin_key

# ------------------------------
# Local MySQL 8.0 (development)
# ------------------------------
DB_CLIENT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tarifario_inbioslab
DB_USER=inbioslab
DB_PASSWORD=change_me_local_password
DB_SSL=false

# ------------------------------
# Cloud SQL (production on Cloud Run)
# ------------------------------
# Recommended: use Cloud SQL Auth Proxy / Cloud SQL connector.
# If using connector, DB_HOST is usually 127.0.0.1 and DB_PORT proxy port.
# Alternative: private IP host in same VPC.
DB_HOST_PROD=127.0.0.1
DB_PORT_PROD=3306
DB_SOCKET_PATH_PROD=/cloudsql/your-project:us-central1:inbioslab-db
DB_NAME_PROD=tarifario_inbioslab
DB_USER_PROD=cloudsql_user
DB_PASSWORD_PROD=change_me_prod_password
DB_SSL_PROD=false
WRITE_API_KEY_PROD=change_me_prod_admin_key
ADMIN_API_KEY_PROD=change_me_prod_super_admin_key

# Cloud SQL metadata (for deployment tooling)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
CLOUD_RUN_SERVICE=tarifario-api
CLOUD_SQL_INSTANCE=your-project:region:instance-name

# Optional secret references (if managed externally)
# DB_PASSWORD_SECRET=projects/<project>/secrets/<secret>/versions/latest
